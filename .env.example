# ===========================================
# BACKEND (Cloud Run - apps/api/)
# ===========================================

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/symione_pay

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=symione-pay
R2_PUBLIC_URL=https://your-bucket.r2.dev

# App
SECRET_KEY=change-this-to-a-random-secret-key
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,https://reliable.app,https://symione.com

# AI validation (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email notifications (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Admin
ADMIN_BOOTSTRAP_TOKEN=your_admin_token_here

# ===========================================
# FRONTEND - Reliable (Vercel - apps/web/)
# ===========================================

NEXT_PUBLIC_API_URL=https://api.symione.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ===========================================
# NOTES
# ===========================================
#
# Backend deploys to Cloud Run:
#   gcloud run deploy symione-api --source apps/api/
#
# Frontend deploys to Vercel:
#   1. Import repo from github.com/echofield/symii
#   2. Set Root Directory to: apps/web
#   3. Framework: Next.js
#   4. Add env vars above
#
# Stripe Connect:
#   - Create a Connect platform in Stripe Dashboard
#   - Enable Express accounts
#   - Set redirect URLs for onboarding
#
# Protocol fee (5%) is baked into transfer logic
# Platform fee (10%) is configurable per challenge
