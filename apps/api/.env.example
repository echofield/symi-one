# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/symione_pay

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=symione-pay
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-bucket.r2.dev

# App
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
# Optional: set to enable POST /api/internal/api-keys (bootstrap API keys)
ADMIN_BOOTSTRAP_TOKEN=
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
PUBLIC_URL=http://localhost:3000

# AI validation (Anthropic — Haiku + Sonnet; single vendor)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_HAIKU=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-20250514
VALIDATION_ESCALATION_THRESHOLD=0.75

# SDK / clients (documentation default)
SYMIONE_API_BASE_URL=https://api.symione.dev
