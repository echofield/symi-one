{
  "name": "@symione-pay/intent-eval",
  "version": "0.1.0",
  "private": true,
  "description": "Intent evaluation engine for SYMIONE PAY - JSONLogic, validators, WASM runtime",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./validators": {
      "types": "./dist/validators/index.d.ts",
      "import": "./dist/validators/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@symione-pay/intent-core": "*",
    "json-logic-js": "^2.0.5",
    "jsonpath-plus": "^10.0.0"
  },
  "devDependencies": {
    "@types/json-logic-js": "^2.0.7",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
